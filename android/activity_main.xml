<?xml version="1.0" encoding="utf-8"?>
<!-- =====================================================================
     Nagad Clone - main dashboard layout containing login and home views.
     Features customized cards, hidden balance overlay, and grid features.
     ===================================================================== -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F5"
    tools:context=".MainActivity">

    <!-- Loading ProgressBar (Global state indicator) -->
    <ProgressBar
        android:id="@+id/pbLoading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="#EC1C24"
        android:visibility="gone" />

    <!-- 1. AUTHENTICATION VIEW CONTAINER (Visible by default) -->
    <LinearLayout
        android:id="@+id/layoutAuth"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:visibility="visible">

        <!-- Logo / Header Accent -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp"
            android:src="@drawable/nagad_logo_vector_placeholder"
            android:contentDescription="Nagad Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Nagad Clone"
            android:textColor="#EC1C24"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure Mobile Financial Service Application"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Phone Card Input -->
        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/input_field_bg"
            android:hint="Mobile Number"
            android:inputType="phone"
            android:maxLength="11"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#222222"
            android:textColorHint="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- PIN Card Input -->
        <EditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/input_field_bg"
            android:hint="4-Digit Nagad PIN"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#222222"
            android:textColorHint="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:backgroundTint="#EC1C24"
            android:text="SIGN IN"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Registration Link -->
        <Button
            android:id="@+id/btnRegister"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Sign Up"
            android:textColor="#F7941D"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- 2. MAIN DASHBOARD VIEW CONTAINER (Hidden by default, shown upon Auth Success) -->
    <LinearLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top Red Dynamic Header Section (Nagad Brand Signature) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EC1C24"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Info Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Arif Rahman"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUserPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01811223344"
                        android:textColor="#FFDDDD"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_avatar_placeholder" />

            </RelativeLayout>

            <!-- Dynamic Tap for Balance Card Button Container -->
            <FrameLayout
                android:id="@+id/btnTapForBalance"
                android:layout_width="200dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/balance_capsule_bg"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Coin Icon -->
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_coin" />

                    <!-- Slideable Hidden/Revealed TextView -->
                    <TextView
                        android:id="@+id/tvBalanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap for Balance"
                        android:textColor="#EC1C24"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Dynamic Feature Grid Section -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Services Grid Card Container -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nagad Core Services"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_marginBottom="16dp" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3"
                            android:rowCount="2"
                            android:alignmentMode="alignMargins"
                            android:columnOrderPreserved="false">

                            <!-- Send Money -->
                            <LinearLayout
                                android:id="@+id/btnSendMoney"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_send_money"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Send Money"
                                    android:textColor="#555555"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Cash Out -->
                            <LinearLayout
                                android:id="@+id/btnCashOut"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_cash_out"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cash Out"
                                    android:textColor="#555555"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Cash In -->
                            <LinearLayout
                                android:id="@+id/btnCashIn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_cash_in"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cash In"
                                    android:textColor="#555555"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Mobile Recharge -->
                            <LinearLayout
                                android:id="@+id/btnRecharge"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp"
                                android:layout_marginTop="8dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_recharge"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Recharge"
                                    android:textColor="#555555"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- History Ledger -->
                            <LinearLayout
                                android:id="@+id/btnHistory"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp"
                                android:layout_marginTop="8dp">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_history"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="History"
                                    android:textColor="#555555"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </GridLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
